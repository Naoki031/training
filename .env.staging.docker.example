# ============================================================
# Base URL — change this one value, everything else derives from it
# ============================================================
APP_URL=https://example.com

# ============================================================
# API
# ============================================================
NODE_ENV=production
API_PREFIX=api/v1
PORT=3001

CLIENT_URL=${APP_URL}

DB_HOST=your-external-db-host
DB_PORT=3306
DB_USER=attendance_staging
DB_PASS=your-db-password
DB_DIALECT=mysql
DB_NAME=attendance_staging

BEARER=Bearer
JWT_KEY=your-jwt-secret
JWT_EXPIRATION_TIME=3600
SALT_ROUNDS=10

TYPEORM_MIGRATIONS=dist/core/database/migrations/**/*.js
TYPEORM_SEEDING_FACTORIES=dist/core/database/factories/**/*.js
TYPEORM_SEEDING_SEEDS=dist/core/database/seeds/**/*.js

GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Leave Requests
GOOGLE_SHEETS_KEY_FILE=/home/attendance_api/secrets/google-sheet.json
GOOGLE_SHEETS_CREDENTIALS=

ZK_DEVICE_IP=
ZK_DEVICE_PORT=4370
ZK_DEVICE_TIMEOUT=5000
ZK_SYNC_FROM_DATE=2025-01-01
ZK_AUTO_SYNC_ENABLED=false
ZK_ALLOWED_SNS=

QR_SECRET=your-qr-secret

ANTHROPIC_API_KEY=
CHATBOT_TONE=professional
CHATBOT_MODEL=claude-sonnet-4-6
TRANSLATE_MODEL=

SLACK_ERROR_WEBHOOK_URL=
SLACK_ERROR_CHANNEL_ID=
SLACK_ERROR_MENTION_USER_IDS=
SLACK_ERROR_MENTION_GROUPS=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Wrap the entire key in double quotes and replace literal newlines with \n
# Example: FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ============================================================
# Client (Nuxt)
# ============================================================
NUXT_PUBLIC_API_BASE_URL=${APP_URL}/api/v1
NUXT_PUBLIC_WS_URL=${APP_URL}

NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
NUXT_PUBLIC_FIREBASE_VAPID_KEY=
