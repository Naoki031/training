# ============================================================
# Base URL — change this one value, everything else derives from it
# ============================================================
APP_URL=https://example.com

# ============================================================
# API
# ============================================================
NODE_ENV=production
API_PREFIX=api/v1
PORT=3001

CLIENT_URL=${APP_URL}

DB_HOST=your-external-db-host
DB_PORT=3306
DB_USER=attendance_staging
DB_PASS=your-db-password
DB_DIALECT=mysql
DB_NAME=attendance_staging

BEARER=Bearer
JWT_KEY=your-jwt-secret
JWT_EXPIRATION_TIME=3600
SALT_ROUNDS=10

TYPEORM_MIGRATIONS=dist/core/database/migrations/**/*.js
TYPEORM_SEEDING_FACTORIES=dist/core/database/factories/**/*.js
TYPEORM_SEEDING_SEEDS=dist/core/database/seeds/**/*.js

GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Leave Requests
GOOGLE_SHEETS_KEY_FILE=/home/attendance_api/secrets/google-sheet.json
GOOGLE_SHEETS_CREDENTIALS=

ZK_DEVICE_IP=
ZK_DEVICE_PORT=4370
ZK_DEVICE_TIMEOUT=5000
ZK_SYNC_FROM_DATE=2025-01-01
ZK_AUTO_SYNC_ENABLED=false
ZK_ALLOWED_SNS=

QR_SECRET=your-qr-secret

ANTHROPIC_API_KEY=
CHATBOT_NAME=HanaBot
CHATBOT_TONE=professional
CHATBOT_MODEL=claude-sonnet-4-6
TRANSLATE_MODEL=

SLACK_ERROR_WEBHOOK_URL=
SLACK_ERROR_CHANNEL_ID=
SLACK_ERROR_MENTION_USER_IDS=
SLACK_ERROR_MENTION_GROUPS=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Wrap the entire key in double quotes and replace literal newlines with \n
# Example: FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# S3 / MinIO storage (for face recognition avatar and check-in photos)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY=your_access_key
AWS_SECRET_KEY=your_secret_key
S3_BUCKET=attendance
# Uncomment if using MinIO instead of AWS S3
# S3_ENDPOINT=https://minio.example.com
# S3_PUBLIC_URL=https://minio.example.com/attendance

# Feature flags — set to "false" to disable for all users except test accounts
# Defaults to enabled (true) if not set
FEATURE_QR_CHECKIN=true
FEATURE_FACE_CHECKIN=true

# Comma-separated user IDs allowed to access disabled features (test accounts)
# Example: TEST_USER_IDS=1,2,3
TEST_USER_IDS=

# ============================================================
# Client (Nuxt)
# ============================================================
NUXT_PUBLIC_API_BASE_URL=${APP_URL}/api/v1
NUXT_PUBLIC_WS_URL=${APP_URL}

NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
NUXT_PUBLIC_FIREBASE_VAPID_KEY=

NUXT_PUBLIC_CHATBOT_NAME=HanaBot

# LiveKit public WebSocket URL — used by the BROWSER to connect to LiveKit
# Proxied through Nginx at /livekit/ → wss://your-domain.com/livekit
NUXT_PUBLIC_LIVEKIT_URL=wss://your-domain.com/livekit

# ============================================================
# LiveKit — WebRTC media server
# ============================================================
LIVEKIT_API_KEY=change-me-32chars-minimum-key
LIVEKIT_API_SECRET=change-me-32chars-minimum-secret
LIVEKIT_HOST=http://attendance_livekit:7880
# Public IP or domain of the staging server — advertised as WebRTC ICE candidate.
# Leave empty to auto-detect via ipify.org (use_external_ip).
LIVEKIT_NODE_IP=
# TURN relay host — same as LIVEKIT_NODE_IP for single-server staging.
# Clients that cannot reach UDP 50000-50200 use TURN over TCP 3478 as fallback.
LIVEKIT_TURN_HOST=your-staging-server-ip

# ============================================================
# TURN / COTURN
# ============================================================
TURN_USERNAME=turn
TURN_PASSWORD=change-me-turn-password
# Public IP of the staging server — coturn uses this for NAT mapping.
# Leave empty to auto-detect via ipify.org.
TURN_EXTERNAL_IP=

# ============================================================
# Whisper — speech-to-text for meeting subtitles
# ============================================================
WHISPER_URL=http://attendance_whisper:5001
# tiny: ~40MB fast, base: ~150MB recommended, small: ~500MB better accuracy
WHISPER_MODEL=large-v3-turbo

# Groq — cloud Whisper API (much faster than local CPU)
# Free tier: 30 req/min, 14400 req/day — sufficient for ~4h/day of meetings
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=
