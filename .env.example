# Ngrok auth token — required for mobile HTTPS testing via 'make ngrok-up'
# Get your token at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_token_here

# LiveKit — WebRTC media server
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_HOST=http://livekit:7880
# LAN IP của máy chủ (MacBook/PC chạy Docker).
# Điện thoại trên cùng WiFi cần direct LAN path thay vì hairpin NAT qua router.
# Lấy IP: `ipconfig getifaddr en0` (Mac) hoặc `ip route get 1 | grep src` (Linux)
# Để trống nếu không dùng điện thoại cùng mạng nội bộ.
LIVEKIT_NODE_IP=
# TURN relay host — must be reachable from ALL clients connecting to the meeting.
# For same-office/LAN testing: set to the same LAN IP as LIVEKIT_NODE_IP (e.g. 192.168.1.x).
# For internet-accessible deployments: set to the server's public IP or domain.
# TURN relay is the fallback when direct UDP (LIVEKIT_NODE_IP) fails (strict NAT, different networks).
LIVEKIT_TURN_HOST=

# Whisper — speech-to-text service
WHISPER_URL=http://whisper:5001
# Model size: tiny (~40MB), base (~150MB), small (~500MB), medium (~1.5GB, recommended)
# large-v3-turbo: distilled from large-v3 — faster than medium, more accurate, less hallucination
WHISPER_MODEL=large-v3-turbo

# Google Cloud TTS — text-to-speech (Wavenet voices)
GOOGLE_TTS_API_KEY=

# Coturn — TURN server for WebRTC relay (needed when devices are on different networks/mobile data)
TURN_USERNAME=turn
TURN_PASSWORD=turnpassword
# Set this to your machine's public IP so external devices can reach the TURN server.
# Leave empty to auto-detect via ipify.org on container startup.
# For ngrok TURN: run `ngrok tcp 3478` and configure livekit.yaml turn_servers section manually.
TURN_EXTERNAL_IP=
